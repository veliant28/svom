# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,svom_backend

# Database
POSTGRES_DB=svom
POSTGRES_USER=svom
POSTGRES_PASSWORD=svom
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Redis
REDIS_CACHE_URL=redis://127.0.0.1:6379/1
REDIS_CELERY_URL=redis://127.0.0.1:6379/2
SUPPLIER_PRICE_LIST_FILE_RETENTION_HOURS=48
SUPPLIER_IMPORT_SCHEDULE_DISPATCH_LOCK_SECONDS=3600

# Elasticsearch
ELASTICSEARCH_HOSTS=http://127.0.0.1:9200
SEARCH_BACKEND=db

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Email
# Resend SMTP. Use a real Resend API key only in local/production env files.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=SVOM <no-reply@svom.com.ua>
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=<RESEND_API_KEY>
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT=10
FRONTEND_BASE_URL=https://svom.com.ua

# UTR anti-ban defaults
UTR_ENABLED=1
UTR_RATE_LIMIT_PER_MINUTE=10
UTR_CONCURRENCY=1
UTR_MAX_RETRIES=3
UTR_BACKOFF_BASE_SECONDS=2
UTR_CIRCUIT_BREAKER_THRESHOLD=5
UTR_CIRCUIT_BREAKER_COOLDOWN_SECONDS=300
UTR_APPLICABILITY_ENABLED=1
UTR_CHARACTERISTICS_ENABLED=0
UTR_FORCE_REFRESH=0
UTR_UNSAFE_ALLOW_FORCE_REFRESH=0
UTR_BATCH_SIZE=25
UTR_RESOLVE_BATCH_SIZE=25
UTR_RESOLVE_STAGE_ORDER=branded_first
UTR_CACHE_TTL_SECONDS=2592000
UTR_SYNC_ENRICH_MAX_PRODUCTS=1
UTR_LAZY_ENRICH_QUEUE_LOCK_SECONDS=600
UTR_LAZY_CATALOG_BATCH_SIZE=25
UTR_LAZY_CATALOG_APPLICABILITY_ENABLED=1
UTR_LAZY_CATALOG_APPLICABILITY_TOP_N=12
UTR_LAZY_APPLICABILITY_QUEUE_LOCK_SECONDS=1800
UTR_LAZY_ENRICH_CHARACTERISTICS_ENABLED=1
UTR_LAZY_ENRICH_APPLICABILITY_ENABLED=1
UTR_SINGLE_RUN_LOCK_KEY=804721451
UTR_SINGLE_RUN_LOCK_TTL_SECONDS=3600
